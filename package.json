{
  "name": "@intellica/data-profiler",
  "version": "1.1.8",
  "description": "Database table profiling CLI: quality scoring, distribution analysis, pattern detection for PostgreSQL & MSSQL",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "intellica-profiler": "./bin/intellica-profiler.js"
  },
  "files": [
    "dist/",
    "bin/",
    "sql/",
    "templates/",
    "config/config.example.yaml",
    "config/config.mock.yaml"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "lint": "eslint src/ --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "data-profiling",
    "database",
    "postgresql",
    "mssql",
    "data-quality",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "commander": "^12.0.0",
    "exceljs": "^4.4.0",
    "figlet": "^1.10.0",
    "gradient-string": "^3.0.0",
    "hdb": "^2.27.1",
    "mssql": "^11.0.0",
    "nunjucks": "^3.2.4",
    "odbc": "^2.5.0",
    "oracledb": "^6.10.0",
    "p-limit": "^7.3.0",
    "pg": "^8.13.0",
    "winston": "^3.14.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.0",
    "@types/figlet": "^1.7.0",
    "@types/gradient-string": "^1.1.6",
    "@types/mssql": "^9.1.9",
    "@types/node": "^20.14.0",
    "@types/nunjucks": "^3.2.6",
    "@types/oracledb": "^6.10.1",
    "@types/pg": "^8.11.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
